{
  "$defs": {
    "ApiError": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "enum": [
            "authentication_failed",
            "validation_error",
            "pipeline_preset_not_found",
            "generation_not_found",
            "step_failed",
            "step_timeout",
            "repair_exhausted",
            "internal_error"
          ],
          "title": "Code",
          "type": "string"
        },
        "field": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Field"
        },
        "message": {
          "minLength": 1,
          "pattern": "\\S",
          "title": "Message",
          "type": "string"
        },
        "trace_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Trace Id"
        }
      },
      "required": [
        "code",
        "message",
        "field",
        "trace_id"
      ],
      "title": "ApiError",
      "type": "object"
    },
    "ApiErrorResponse": {
      "additionalProperties": false,
      "properties": {
        "errors": {
          "items": {
            "$ref": "#/$defs/ApiError"
          },
          "title": "Errors",
          "type": "array"
        }
      },
      "required": [
        "errors"
      ],
      "title": "ApiErrorResponse",
      "type": "object"
    },
    "WorkerReplyMetadata": {
      "additionalProperties": false,
      "properties": {
        "agent_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Agent Name"
        },
        "cost_usd": {
          "default": 0,
          "minimum": 0,
          "title": "Cost Usd",
          "type": "number"
        },
        "latency_ms": {
          "default": 0,
          "minimum": 0,
          "title": "Latency Ms",
          "type": "integer"
        },
        "model": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Model"
        },
        "prompt_version": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Prompt Version"
        },
        "provider": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Provider"
        },
        "repair_attempts": {
          "default": 0,
          "minimum": 0,
          "title": "Repair Attempts",
          "type": "integer"
        },
        "tokens_in": {
          "default": 0,
          "minimum": 0,
          "title": "Tokens In",
          "type": "integer"
        },
        "tokens_out": {
          "default": 0,
          "minimum": 0,
          "title": "Tokens Out",
          "type": "integer"
        },
        "trace_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Trace Id"
        }
      },
      "title": "WorkerReplyMetadata",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "error_json": {
      "$ref": "#/$defs/ApiErrorResponse"
    },
    "ok": {
      "const": false,
      "default": false,
      "title": "Ok",
      "type": "boolean"
    },
    "output_json": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Output Json"
    },
    "reply_metadata": {
      "$ref": "#/$defs/WorkerReplyMetadata"
    }
  },
  "required": [
    "error_json",
    "reply_metadata"
  ],
  "title": "StepRpcFailureReply",
  "type": "object"
}
