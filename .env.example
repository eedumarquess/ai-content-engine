POSTGRES_DB=ai_content_engine
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://app:app@postgres:5432/ai_content_engine
DATABASE_URL_LOCAL=postgresql://app:app@localhost:5432/ai_content_engine

RABBITMQ_DEFAULT_USER=app
RABBITMQ_DEFAULT_PASS=app
RABBITMQ_DEFAULT_VHOST=ai-content-engine
RABBITMQ_AMQP_HOST_PORT=5672
RABBITMQ_MANAGEMENT_HOST_PORT=15672
AMQP_URL=amqp://app:app@rabbitmq:5672/ai-content-engine
AMQP_URL_LOCAL=amqp://app:app@localhost:5672/ai-content-engine
CONTENT_RPC_QUEUE=content.rpc
REVIEW_RPC_QUEUE=review.rpc
STEP_DLQ_QUEUE=steps.dlq

OLLAMA_HOST_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_BASE_URL_LOCAL=http://localhost:11434
OLLAMA_MAIN_MODEL=qwen2.5:7b
OLLAMA_REPAIR_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

EMBEDDING_DIM=768
RERANKER_MODEL=BAAI/bge-reranker-base
HF_HOME=/data/hf
TRANSFORMERS_CACHE=/data/hf

NODE_ENV=development
PYTHON_ENV=development
ORCHESTRATOR_PORT=3000
ORCHESTRATOR_HOST_PORT=3000
HEARTBEAT_INTERVAL_SECONDS=30

AUTH_REALM=AI Content Engine
AUTH_BOOTSTRAP_ADMIN_EMAIL=local-admin@example.com
AUTH_BOOTSTRAP_ADMIN_PASSWORD=change-me
